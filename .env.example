# Local dev only — on Vercel set this per environment (see README).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth — Clerk (https://dashboard.clerk.com → API keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Host Clerk's sign-in/up on our own branded pages.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Supabase (database only — auth is handled by Clerk via third-party auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI insights
ANTHROPIC_API_KEY=

# Lead capture and report sends
RESEND_API_KEY=
NOTIFICATION_EMAIL=

# Connector OAuth
META_APP_ID=
META_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# Scheduled jobs
CRON_SECRET=

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
